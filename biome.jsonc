{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"ignoreUnknown": false,
		"includes": ["**/*.ts", "**/*.json", "**/*.js"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git"
	}
}
